{
  "name": "codex-github-context-resume",
  "displayName": "Codex/GitHub文脈再開支援",
  "version": "0.1.0",
  "publisher": "sunmax0731",
  "private": false,
  "description": "VS Code内でワークスペース、Issue、ブランチ、再開メモをまとめて確認する。",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:codex-github-context-resume.openReview"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codex-github-context-resume.openReview",
        "title": "Codex/GitHub文脈再開支援: レビューを開く"
      }
    ]
  },
  "scripts": {
    "test": "node --test tests/*.test.cjs && node tools/qcds-evaluate.cjs && node tools/platform-runtime-gate.mjs && node tools/closed-alpha-guard.mjs",
    "validate": "npm test",
    "platform:gate": "node tools/platform-runtime-gate.mjs",
    "closed-alpha:guard": "node tools/closed-alpha-guard.mjs"
  },
  "devDependencies": {},
  "license": "MIT",
  "keywords": [
    "vscodeextension",
    "qcds",
    "pre-release",
    "strict-qcds",
    "representative-suite"
  ]
}
